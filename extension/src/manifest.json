{
  "manifest_version": 3,
  "name": "Web Content Audit",
  "version": "0.1.0",
  "description": "Audit wiki pages against configurable rules",
  "permissions": ["activeTab", "storage", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.feishu.cn/*", "*://*.larksuite.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "host_permissions": ["http://localhost:3200/*", "http://127.0.0.1:3200/*"]
}
