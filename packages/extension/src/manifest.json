{
  "manifest_version": 3,
  "name": "Web Content Audit",
  "version": "0.1.0",
  "description": "Audit wiki pages against configurable rules",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.feishu.cn/*", "*://*.larksuite.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "host_permissions": ["http://localhost:3200/*", "http://127.0.0.1:3200/*"]
}
